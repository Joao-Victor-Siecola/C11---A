import numpy as np


arr1 = np.ones(8)


np.random.seed(5)
arr2 = np.random.randint(0, 10, 8)


arr3 = arr1 + arr2

print("Array resultante:", arr3)
print("Soma total:", arr3.sum())


if arr3.sum() >= 40:

    arr3 = arr3.reshape(4, 2)
else:

    arr3 = arr3.reshape(2, 4)

print("Array remodelado:")
print(arr3)
